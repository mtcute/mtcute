{
  "name": "@mtcute/core",
  "type": "module",
  "version": "0.30.3",
  "private": true,
  "description": "Type-safe library for MTProto (Telegram API)",
  "author": "alina sireneva <alina@tei.su>",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./utils.js": "./src/utils/index.ts",
    "./client.js": "./src/highlevel/client.ts",
    "./worker.js": "./src/highlevel/worker/index.ts",
    "./methods.js": "./src/highlevel/methods.ts",
    "./tl/api-schema.json": "./src/tl/api-schema.json",
    "./tl/app-config.json": "./src/tl/app-config.json",
    "./tl/raw-errors.json": "./src/tl/raw-errors.json",
    "./tl/mtp-schema.json": "./src/tl/mtp-schema.json"
  },
  "scripts": {
    "gen-client": "node ./scripts/generate-client.cjs",
    "gen-updates": "node ./scripts/generate-updates.cjs",
    "gen-tl": "tsx ./scripts/tl/gen-code.ts"
  },
  "dependencies": {
    "@fuman/io": "0.0.21",
    "@fuman/net": "0.0.21",
    "@fuman/utils": "0.0.21",
    "@mtcute/file-id": "workspace:^",
    "@mtcute/tl-runtime": "workspace:^",
    "@types/events": "3.0.0",
    "long": "catalog:"
  },
  "devDependencies": {
    "@mtcute/test": "workspace:^",
    "@mtcute/tl-utils": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "cheerio": "^1.2.0",
    "csv-parse": "^7.0.1",
    "js-yaml": "^5.2.1"
  }
}